{%- comment -%}
  AT: Access Threads duplicate of popup-link. Use this block when you need
  bulk order grid support. Original popup-link is unchanged.
{%- endcomment -%}
{% assign block_settings = block.settings %}

<script
  src="{{ 'dialog.js' | asset_url }}"
  type="module"
></script>

{%- if block_settings.at_enable_bulk_grid -%}
  {{ 'at-bulk-grid.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'at-bulk-grid.js' | asset_url }}?v=6" type="module"></script>
{%- endif -%}

<dialog-component
  class="popup-link at-popup-link"
  {{ block.shopify_attributes }}
>
  <button
    on:click="/showDialog"
    class="button button-unstyled popup-link__button text-left spacing-style {{ block_settings.type_preset }}"
    style="{% render 'spacing-style', settings: block_settings %}"
  >
    {{- block_settings.heading }}
    {{- 'icon-external.svg' | inline_asset_content -}}
  </button>

  {%- if block_settings.at_enable_bulk_grid -%}
    <button
      type="button"
      on:click="/showDialog"
      class="button button-unstyled popup-link__button product-form__bulk-button at-bulk-grid-trigger spacing-style {{ block_settings.type_preset }}"
      style="{% render 'spacing-style', settings: block_settings %}"
      data-at-bulk-grid-trigger
    >
      {{ block_settings.at_bulk_trigger_label }}
    </button>
  {%- endif -%}

  <dialog
    ref="dialog"
    class="popup-link__content dialog-modal color-custom-popover{% if block_settings.behavior == 'drawer' %} popup-link__content--drawer dialog-drawer{% endif %}"
    scroll-lock
    aria-labelledby="at-popup-dialog-heading-{{ block.id }}"
  >
    {%- assign at_popup_heading_id = 'at-popup-dialog-heading-' | append: block.id -%}
    {%- unless block_settings.at_enable_bulk_grid -%}
      <h2
        id="{{ at_popup_heading_id }}"
        class="visually-hidden"
      >
        {{ block_settings.heading }}
      </h2>
    {%- endunless -%}
    <div class="popup-link__inner">
      {%- if block_settings.at_enable_bulk_grid -%}
        {% render 'at-bulk-grid-header', heading_id: at_popup_heading_id, title: block_settings.heading %}
      {%- endif -%}
      {%- if block_settings.at_enable_bulk_grid and settings.at_discount_progress_enabled -%}
        {%- assign at_popup_dp_section_id = section.id | append: '-' | append: block.id -%}
        <div class="at-dp-condensed-strip--tight at-discount-progress-scheme-wrap">
          {% render 'at-discount-progress',
            context: 'bulk-modal',
            layout: 'drawer_header',
            section_id: at_popup_dp_section_id,
            non_sale_collection_url: settings.at_non_sale_collection_url
          %}
        </div>
      {%- endif -%}
      {%- if block_settings.at_enable_bulk_grid -%}
        <div class="at-bulk-grid" data-at-bulk-grid data-at-bulk-grid-section-id="{{ section.id }}" data-at-bulk-grid-block-id="{{ block.id }}" data-at-bulk-loading-label="{{ 'accessibility.loading_variants' | t }}" data-at-bulk-add-to-cart-animation="{{ settings.add_to_cart_animation }}" data-at-bulk-auto-open-cart="{{ settings.auto_open_cart_drawer }}">
          {%- comment -%} Bulk grid content rendered by at-bulk-grid.js from data provided by AT variant picker {%- endcomment -%}
        </div>
      {%- endif -%}
      {% content_for 'blocks' %}
    </div>
    <button
      ref="closeButton"
      on:click="/closeDialog"
      class="button button-unstyled close-button popup-link__close"
      aria-label="{{ 'accessibility.close_dialog' | t }}"
    >
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>
  </dialog>
</dialog-component>

{% stylesheet %}
  .popup-link__button svg {
    display: inline-block;
    position: relative;
    top: var(--margin-2xs);
  }

  .popup-link__content {
    box-shadow: var(--shadow-popover);
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    background-color: var(--color-background);
    padding: var(--padding-4xl) var(--padding-xl) var(--padding-xl);
    max-width: var(--wide-content-width);
    max-height: var(--modal-max-height);

    @media screen and (min-width: 750px) {
      padding: var(--padding-5xl);
      /* Cap width to viewport so page never scrolls horizontally */
      max-width: min(var(--normal-content-width), calc(100vw - 2rem));
    }
  }

  /* Allow inner content to use full width; bulk grid modal overrides max-width via at-bulk-grid.css */
  .popup-link__inner {
    min-width: 0;
    overflow-x: auto;
  }

  .popup-link__content[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .popup-link__content.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .popup-link__content--drawer {
    position: fixed;
    border-radius: 0;
    width: var(--sidebar-width);
    max-width: 95vw;
    height: 100%;
    margin: 0 0 0 auto;
  }

  .popup-link__content--drawer:modal {
    max-height: 100dvh;
  }

  .popup-link__close {
    top: var(--margin-2xs);
    right: var(--margin-2xs);
    opacity: 0.8;
    animation: none;
  }

  .at-popup-link .at-bulk-grid-trigger {
    display: block;
    margin-block-start: var(--gap-xs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "AT Popup link",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.popup"
    },
    {
      "type": "select",
      "id": "behavior",
      "label": "t:settings.behavior",
      "options": [
        {
          "value": "default",
          "label": "t:options.default"
        },
        {
          "value": "drawer",
          "label": "t:options.drawer"
        }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "t:content.link"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.text",
      "default": "t:text_defaults.popup_link"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "",
          "label": "t:options.default"
        },
        {
          "value": "paragraph",
          "label": "t:options.paragraph"
        },
        {
          "value": "h1",
          "label": "t:options.h1"
        },
        {
          "value": "h2",
          "label": "t:options.h2"
        },
        {
          "value": "h3",
          "label": "t:options.h3"
        },
        {
          "value": "h4",
          "label": "t:options.h4"
        },
        {
          "value": "h5",
          "label": "t:options.h5"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "header",
      "content": "Bulk order (Access Threads)"
    },
    {
      "type": "checkbox",
      "id": "at_enable_bulk_grid",
      "label": "Enable bulk order grid in this popup",
      "default": false
    },
    {
      "type": "text",
      "id": "at_bulk_trigger_label",
      "label": "Bulk order trigger label",
      "default": "Bulk order (24+)"
    },
    {
      "type": "header",
      "content": "t:content.link_padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "AT Popup link",
      "category": "t:categories.links",
      "settings": {
        "heading": "Bulk Add",
        "at_bulk_trigger_label": "Bulk order (24+)"
      },
      "blocks": {}
    }
  ]
}
{% endschema %}
