{%- doc -%}
  Access Threads: Bulk Add to Cart trigger + dialog for the AT bulk grid.
  Nest under AT Buy buttons so merchants can reorder it relative to the quantity / add to cart row.

  @example
  {% content_for 'block', type: 'at-bulk-add-to-cart', id: 'bulk-add-to-cart' %}
{%- enddoc -%}
{% liquid
  assign block_settings = block.settings
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign style_class = block_settings.style_class | default: 'button-secondary'
  assign scoped_class = style_class | append: '--' | append: block.id
  assign trigger_label = block_settings.at_bulk_trigger_label | default: 'Bulk Add to Cart'
%}

{%- if product != blank -%}
  <script
    src="{{ 'dialog.js' | asset_url }}"
    type="module"
  ></script>
  {{ 'at-bulk-grid.css' | asset_url | stylesheet_tag }}
  <script
    src="{{ 'at-bulk-grid.js' | asset_url }}?v=5"
    type="module"
  ></script>

  {% render 'button-custom-styles', block_settings: block_settings, block_id: block.id %}
  {%- render 'at-bulk-grid-config', product_resource: product -%}

  <dialog-component
    class="at-buy-buttons__bulk-popup-component"
    {{ block.shopify_attributes }}
  >
    <button
      type="button"
      on:click="/showDialog"
      class="button at-buy-buttons__bulk-trigger {{ style_class }} {{ scoped_class }}"
      data-at-bulk-grid-trigger
      style="--add-to-cart-font-case: {{ settings.button_text_case }};"
    >
      <span class="add-to-cart-text">
        <span
          aria-hidden="true"
          class="svg-wrapper add-to-cart-icon"
        >
          {{- 'at-bulk-add-to-cart.svg' | inline_asset_content -}}
        </span>
        <span class="add-to-cart-text__content">
          {{ trigger_label }}
        </span>
      </span>
    </button>

    <dialog
      ref="dialog"
      class="at-buy-buttons__bulk-dialog dialog-modal color-custom-popover{% if block_settings.at_bulk_behavior == 'drawer' %} at-buy-buttons__bulk-dialog--drawer dialog-drawer{% endif %}"
      scroll-lock
      aria-labelledby="at-bulk-dialog-heading-{{ block.id }}"
    >
      <h2
        id="at-bulk-dialog-heading-{{ block.id }}"
        class="visually-hidden"
      >
        {{ trigger_label }}
      </h2>
      <div class="at-buy-buttons__bulk-dialog-inner">
        {% if settings.at_discount_progress_enabled %}
          <div class="at-dp-condensed-strip--tight at-discount-progress-scheme-wrap color-custom-at-discount-progress">
            {% render 'at-discount-progress',
              context: 'bulk-modal',
              layout: 'drawer_header',
              section_id: section.id | append: '-' | append: block.id,
              non_sale_collection_url: settings.at_non_sale_collection_url
            %}
          </div>
        {% endif %}
        <div
          class="at-bulk-grid"
          data-at-bulk-grid
          data-at-bulk-grid-section-id="{{ section.id }}"
          data-at-bulk-grid-block-id="{{ block.id }}"
          data-at-bulk-loading-label="{{ 'accessibility.loading_variants' | t }}"
          data-at-bulk-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
          data-at-bulk-auto-open-cart="{{ settings.auto_open_cart_drawer }}"
        ></div>
      </div>
      <button
        ref="closeButton"
        on:click="/closeDialog"
        class="button button-unstyled close-button at-buy-buttons__bulk-close"
        aria-label="{{ 'accessibility.close_dialog' | t }}"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </dialog>
  </dialog-component>
{%- endif -%}

{% stylesheet %}
  .at-buy-buttons__bulk-popup-component {
    display: block;
    width: 100%;
    margin-block-end: var(--gap-sm);
  }

  .at-buy-buttons__bulk-trigger {
    width: 100%;
    height: var(--height-buy-buttons);
    padding-block: var(--padding-lg);
    text-transform: var(--button-text-case-primary);
  }

  .at-buy-buttons__bulk-trigger.button-secondary {
    text-transform: var(--button-text-case-secondary);
  }

  .at-buy-buttons__bulk-dialog {
    box-shadow: var(--shadow-popover);
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    background-color: var(--color-background);
    padding: var(--padding-4xl) var(--padding-xl) var(--padding-xl);
    max-width: var(--wide-content-width);
    max-height: var(--modal-max-height);

    @media screen and (min-width: 750px) {
      padding: var(--padding-5xl);
      max-width: min(var(--page-content-width), calc(100vw - 2rem));
      max-height: min(85dvh, 90svh);
    }
  }

  .at-buy-buttons__bulk-dialog[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .at-buy-buttons__bulk-dialog.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .at-buy-buttons__bulk-dialog--drawer {
    position: fixed;
    border-radius: 0;
    width: var(--sidebar-width);
    max-width: 95vw;
    height: 100%;
    margin: 0 0 0 auto;
  }

  .at-buy-buttons__bulk-dialog--drawer:modal {
    max-height: 100dvh;
  }

  .at-buy-buttons__bulk-dialog-inner {
    min-width: 0;
    overflow-x: auto;
  }

  .at-buy-buttons__bulk-close {
    top: var(--margin-2xs);
    right: var(--margin-2xs);
    opacity: 0.8;
    animation: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.at_bulk_add_to_cart",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "at_bulk_trigger_label",
      "label": "t:settings.label",
      "default": "Bulk Add to Cart"
    },
    {
      "type": "select",
      "id": "at_bulk_behavior",
      "label": "t:settings.at_bulk_modal_style",
      "options": [
        {
          "value": "default",
          "label": "t:options.modal"
        },
        {
          "value": "drawer",
          "label": "t:options.drawer"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "button-unstyled",
          "label": "t:options.link"
        },
        {
          "value": "button-custom",
          "label": "t:options.custom"
        }
      ],
      "default": "button-secondary",
      "info": "t:info.edit_button_style_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.button_colors",
      "visible_if": "{{ block.settings.style_class == \"button-custom\" }}"
    },
    {
      "type": "color",
      "id": "custom_button_background",
      "label": "t:settings.background",
      "default": "{{ settings.color_palette.foreground }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_text",
      "label": "t:settings.text",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_border",
      "label": "t:settings.borders",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "link_text_color",
      "label": "t:settings.link_text_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.style_class == 'button-unstyled' }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.at_bulk_add_to_cart",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
