{%- doc -%}
  Compact cart drawer header: cart icon + item count, optional discount strip, close control.

  @param {string} section_id - Section id for at-discount-progress.
  @param {string} [heading_id] - Id for the visually hidden cart title (dialog aria-labelledby).
{%- enddoc -%}
{%- liquid
  assign drawer_heading_id = heading_id | default: 'cart-drawer-heading'
-%}
<div class="cart-drawer__header" id="cart-drawer-header">
  <div class="cart-drawer__header-top">
    <div class="cart-drawer__cart-mark">
      <h2 class="visually-hidden" id="{{ drawer_heading_id }}">
        {{ 'content.cart_title' | t }}
        {%- unless cart.empty? -%}
          {{- 'accessibility.cart_count' | t }}: {{ cart.item_count -}}
        {%- endunless -%}
      </h2>
      {%- comment -%}
        Mirror header cart trigger: `button.header-actions__action` > `cart-icon` (see sections/header.liquid action svg sizing).
      {%- endcomment -%}
      <span class="header-actions__action cart-drawer__header-cart-action" aria-hidden="true">
        <cart-icon
          class="header-actions__cart-icon{% unless cart == empty %} header-actions__cart-icon--has-cart{% endunless %}"
          data-testid="cart-drawer-header-cart-icon"
        >
          <span class="hidden">
            {{ 'content.cart_title' | t }}
          </span>

          <span class="svg-wrapper" aria-hidden="true">
            {{- 'icon-cart.svg' | inline_asset_content -}}
          </span>

          {% render 'cart-bubble', limit: 100, text_id: 'cart-drawer-bubble-text' %}
        </cart-icon>
      </span>
    </div>

    {% if settings.at_discount_progress_enabled %}
      <div
        class="cart-drawer__at-dp-strip at-discount-progress-scheme-wrap"
      >
        {% render 'at-discount-progress',
          context: 'cart',
          layout: 'drawer_header',
          section_id: section_id,
          non_sale_collection_url: settings.at_non_sale_collection_url
        %}
      </div>
    {% endif %}

    <button
      ref="closeButton"
      type="button"
      on:click="#cart-drawer/close"
      class="theme-drawer__close-button cart-drawer__close-button"
      aria-label="{{ 'actions.close' | t }}"
    >
      <span class="svg-wrapper">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>
</div>
