{%- doc -%}
  Renders the AT mega-panel: a full-width dropdown with a left category
  sidebar and a right content area, matching the BrandDirectory-style layout.

  The left sidebar is populated from `categories_linklist`. When the active
  sidebar item's handle matches `brands_handle`, the right pane shows the full
  brand grid sourced from `brands_linklist`. For every other sidebar item the
  right pane renders that item's sub-links as a navigation grid.

  @param {object} panel_link          - The top-level nav link that triggers this panel.
  @param {object} categories_linklist - Linklist whose links populate the sidebar (required).
  @param {object} [brands_linklist]   - Linklist whose links are displayed as the brand grid.
  @param {string} [brands_handle]     - Handle of the sidebar item that should show the brand grid.
  @param {object} section             - The block object (used for settings).

  Architecture note (perf)
  ------------------------
  Renders only the lightweight chrome: the trigger button, sidebar
  category buttons, and per-category content headers (title + search
  input + count badge). The actual brand grid and per-category subnav
  grids live in `sections/at-menu-data.liquid` and are fetched on
  demand by assets/at-menu.js when the user first hovers the AT nav.
  This keeps initial HTML tiny on every page, including for crawlers.
{%- enddoc -%}

{%- liquid
  assign block_settings = section.settings
  assign show_search    = block_settings.at_show_brand_search
  assign brand_total    = brands_linklist.links.size | default: 0
  assign panel_id         = 'at-panel-' | append: panel_link.handle
  assign brands_grid_id   = 'at-brands-grid-' | append: panel_link.handle
  assign brands_search_id = 'at-brands-search-' | append: panel_link.handle
  assign brands_handle    = brands_handle | default: 'brands'
-%}

<at-brands-panel
  class="at-brands-panel"
  on:pointerenter="/open"
>
  {%- comment -%} ── Trigger ── {%- endcomment -%}
  <button
    ref="trigger"
    class="menu-list__link at-menu__nav-link"
    aria-expanded="false"
    aria-controls="{{ panel_id }}"
    aria-haspopup="true"
    on:click="/open"
  >
    <span class="menu-list__link-title">{{- panel_link.title -}}</span>
    <span class="at-menu__nav-link-chevron svg-wrapper icon-caret" aria-hidden="true">
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </span>
  </button>

  {%- comment -%} ── Dropdown panel ── {%- endcomment -%}
  <div
    id="{{ panel_id }}"
    ref="panel"
    class="at-brands-panel__dropdown"
    hidden
  >
    {%- comment -%} ── Left: category sidebar ── {%- endcomment -%}
    <div class="at-brands-panel__sidebar" role="navigation" aria-label="Product categories">
      <ul class="list-unstyled" role="list">
        {%- for cat_link in categories_linklist.links -%}
          {%- assign is_first = forloop.first -%}
          <li>
            <button
              class="at-brands-panel__cat-btn{% if is_first %} at-brands-panel__cat-btn--active{% endif %}"
              data-cat="{{ cat_link.handle }}"
              on:click="/switchCategory"
              aria-pressed="{{ is_first }}"
              type="button"
            >
              <span>{{- cat_link.title -}}</span>
              {%- unless cat_link.links == blank or cat_link.handle == brands_handle -%}
                <span class="at-brands-panel__cat-chevron svg-wrapper" aria-hidden="true">
                  {{- 'icon-chevron-right.svg' | inline_asset_content -}}
                </span>
              {%- endunless -%}
            </button>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ── Right: content area ── {%- endcomment -%}
    <div class="at-brands-panel__content">

      {%- for cat_link in categories_linklist.links -%}
        {%- assign is_first   = forloop.first -%}
        {%- assign is_brands  = false -%}
        {%- if cat_link.handle == brands_handle -%}
          {%- assign is_brands = true -%}
        {%- endif -%}

        {%- if is_brands -%}
          {%- comment -%} ── Brand grid panel ── {%- endcomment -%}
          <div
            class="at-brands-panel__cat-content"
            data-cat="{{ cat_link.handle }}"
            {% unless is_first %}hidden{% endunless %}
          >
            {%- comment -%} Header row: heading + optional search + count {%- endcomment -%}
            <div class="at-brands-panel__content-header">
              <h2 class="at-brands-panel__heading">{{ cat_link.title }}</h2>

              {%- if show_search -%}
                <div class="at-brands-panel__search-wrapper" role="search">
                  <span class="at-brands-panel__search-icon svg-wrapper" aria-hidden="true">
                    {{- 'icon-search.svg' | inline_asset_content -}}
                  </span>
                  <label for="{{ brands_search_id }}" class="visually-hidden">Search brands</label>
                  <input
                    ref="searchInput"
                    id="{{ brands_search_id }}"
                    type="search"
                    class="at-brands-panel__search"
                    placeholder="Search brands…"
                    autocomplete="off"
                    aria-controls="{{ brands_grid_id }}"
                    aria-label="Search brands"
                  >
                  <button
                    ref="searchClear"
                    type="button"
                    class="at-brands-panel__search-clear"
                    aria-label="Clear search"
                    hidden
                  >
                    <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
                  </button>
                </div>
              {%- endif -%}

              <span
                ref="countBadge"
                class="at-brands-panel__count"
                aria-live="polite"
                aria-atomic="true"
              >
                {{- brand_total -}}
              </span>
            </div>

            {%- comment -%}
              Desktop: placeholder until at-menu-data is adopted (hidden via JS once loaded).
              Spinner matches AT mobile drawer / panel loading ring (at-menu.css).
            {%- endcomment -%}
            <div
              class="at-brands-panel__async-loading"
              data-at-async-loading
              hidden
            >
              <div class="at-brands-panel__spinner" role="status">
                <span class="visually-hidden">{{ 'accessibility.loading_menu' | t }}</span>
              </div>
            </div>

            {%- comment -%}
              Brand grid is fetched on demand from at-menu-data and
              adopted into this cat-content panel by assets/at-menu.js.
              See sections/at-menu-data.liquid.
            {%- endcomment -%}

            {%- if cat_link.url != blank -%}
              <div class="at-brands-panel__footer">
                <a href="{{ cat_link.url }}" class="at-brands-panel__view-all">
                  View all {{ brand_total }} brands &rarr;
                </a>
              </div>
            {%- endif -%}
          </div>

        {%- else -%}
          {%- comment -%} ── Category sub-nav panel ── {%- endcomment -%}
          <div
            class="at-brands-panel__cat-content at-brands-panel__subnav"
            data-cat="{{ cat_link.handle }}"
            {% unless is_first %}hidden{% endunless %}
          >
            <div class="at-brands-panel__content-header">
              <h2 class="at-brands-panel__heading">
                <a href="{{ cat_link.url }}" class="at-brands-panel__heading-link">
                  {{- cat_link.title -}}
                </a>
              </h2>
              {%- if cat_link.url != blank -%}
                <a href="{{ cat_link.url }}" class="at-brands-panel__view-all at-brands-panel__view-all--header">
                  Shop all &rarr;
                </a>
              {%- endif -%}
            </div>

            {%- if cat_link.links == blank -%}
              <div class="at-brands-panel__placeholder">
                <a href="{{ cat_link.url }}" class="button button--secondary button--small">
                  Shop {{ cat_link.title }} &rarr;
                </a>
              </div>
            {%- endif -%}

            <div
              class="at-brands-panel__async-loading"
              data-at-async-loading
              hidden
            >
              <div class="at-brands-panel__spinner" role="status">
                <span class="visually-hidden">{{ 'accessibility.loading_menu' | t }}</span>
              </div>
            </div>

            {%- comment -%}
              Category subnav grid is fetched on demand from at-menu-data
              and adopted into this cat-content panel by assets/at-menu.js
              when the user activates this category.
            {%- endcomment -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</at-brands-panel>
