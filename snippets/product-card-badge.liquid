{%- doc -%}
  Resolves and renders the highest-priority product card badge.

  @param {object} product - Product resource used to determine badge eligibility.
{%- enddoc -%}

{%- liquid
  assign badge_label = blank
  assign badge_class = 'color-custom-badge-sale'

  if product != blank
    if product.available == false
      assign badge_label = 'content.product_badge_sold_out' | t
      assign badge_class = 'color-custom-badge-sold-out'
    elsif product.compare_at_price > product.price
      assign badge_label = 'content.product_badge_sale' | t
      assign badge_class = 'color-custom-badge-sale'
    else
      assign badge_slots = '1,2,3,4,5,6,7,8' | split: ','

      for badge_slot in badge_slots
        assign enabled_setting_id = 'badge_custom_' | append: badge_slot | append: '_enabled'
        assign label_setting_id = 'badge_custom_' | append: badge_slot | append: '_label'
        assign tag_setting_id = 'badge_custom_' | append: badge_slot | append: '_tag'

        if settings[enabled_setting_id]
          assign custom_badge_label = settings[label_setting_id] | strip
          assign custom_badge_tag = settings[tag_setting_id] | strip | downcase

          if custom_badge_label != blank and custom_badge_tag != blank
            for product_tag in product.tags
              assign normalized_product_tag = product_tag | strip | downcase

              if normalized_product_tag == custom_badge_tag
                assign badge_label = custom_badge_label
                assign badge_class = 'color-custom-badge-sale'
                break
              endif
            endfor
          endif
        endif

        if badge_label != blank
          break
        endif
      endfor
    endif
  endif
-%}

{%- if badge_label != blank -%}
  <div class="product-badges__badge product-badges__badge--rectangle {{ badge_class }}">
    {{ badge_label | escape }}
  </div>
{%- endif -%}
