{%- doc -%}
  Access Threads: member tier discount progress bar (cart, drawer, PDP, bulk modal).

  @param {string} context - 'cart' | 'bulk-modal' | 'product' — all use the same condensed strip + “Bulk savings” sheet (PDP includes pending line in preview; bulk sums grid qty)
  @param {string} [section_id] - Unique id suffix for a11y (popover). Defaults to 'cart'.
  @param {number} [product_price] - Selected variant price in cents (product context).
  @param {object} [product] - Product for data-product-id (product context).
  @param {string} [non_sale_collection_url] - Link for qualifying items in info panel.
  @param {string} [customer_account_menu] - Menu handle for shopify-account (default matches header: customer-account-main-menu).
  @param {string} [layout] - 'drawer_header' for inline “Get member discounts” + Log in (cart drawer header, bulk modals when logged out); default is the card prompt.
{%- enddoc -%}
{%- liquid
  assign dp_customer_account_menu = customer_account_menu | default: 'customer-account-main-menu'
  assign dp_layout = layout | default: ''
  assign dp_context = context | default: 'cart'
  assign dp_section = section_id | default: 'global'
  assign dp_uid = dp_section | append: '-' | append: dp_context | handleize
  assign dp_non_sale_url = non_sale_collection_url | default: settings.at_non_sale_collection_url
  assign dp_empty_track = settings.at_discount_progress_empty_track | default: 'tinted'
  assign dp_subtotal = cart.items_subtotal_price
  assign dp_product_price = product_price | default: 0
  assign dp_product_id = ''
  if product != blank
    assign dp_product_id = product.id
  endif
  assign milestones_json = '[{"threshold":15000,"name":"12% Bulk Discount","benefitShort":"off non-sale items","benefitLabel":"12%"},{"threshold":20000,"name":"Free shipping","benefitShort":"Free shipping","benefitLabel":"Free ship","kind":"shipping"},{"threshold":30000,"name":"15% Bulk Discount","benefitShort":"off non-sale items","benefitLabel":"15%"},{"threshold":75000,"name":"18% Bulk Discount","benefitShort":"off non-sale items","benefitLabel":"18%"},{"threshold":150000,"name":"20% Bulk Discount","benefitShort":"off non-sale items","benefitLabel":"20%"},{"threshold":300000,"name":"25% Bulk Discount","benefitShort":"off non-sale items","benefitLabel":"25%"}]'
-%}
{%- capture dp_i18n -%}
{"close_dialog":{{ 'accessibility.close_dialog' | t | json }},"log_in_prompt":{{ 'at_discount_progress.log_in_prompt' | t | json }},"log_in":{{ 'at_discount_progress.log_in' | t | json }},"tier_unlocked":{{ 'at_discount_progress.tier_unlocked' | t | json }},"achievement_none":{{ 'at_discount_progress.achievement_none' | t | json }},"add_more_for":{{ 'at_discount_progress.add_more_for' | t | json }},"cart_condensed_status":{{ 'at_discount_progress.cart_condensed_status' | t | json }},"max_tier_reached":{{ 'at_discount_progress.max_tier_reached' | t | json }},"non_sale_disclaimer":{{ 'at_discount_progress.non_sale_disclaimer' | t | json }},"browse_qualifying":{{ 'at_discount_progress.browse_qualifying' | t | json }},"info_open":{{ 'at_discount_progress.info_open' | t | json }},"info_close":{{ 'at_discount_progress.info_close' | t | json }},"preview_helper":{{ 'at_discount_progress.preview_helper' | t | json }},"bulk_savings_title":{{ 'at_discount_progress.bulk_savings_title' | t | json }},"bulk_savings_subtitle":{{ 'at_discount_progress.bulk_savings_subtitle' | t | json }},"expand_savings_aria":{{ 'at_discount_progress.expand_savings_aria' | t | json }},"modal_got_it":{{ 'at_discount_progress.modal_got_it' | t | json }},"unlocked_badge":{{ 'at_discount_progress.unlocked_badge' | t | json }},"modal_unlocked_at":{{ 'at_discount_progress.modal_unlocked_at' | t | json }},"modal_spend_for":{{ 'at_discount_progress.modal_spend_for' | t | json }},"modal_at":{{ 'at_discount_progress.modal_at' | t | json }},"modal_away":{{ 'at_discount_progress.modal_away' | t | json }},"modal_footer_note":{{ 'at_discount_progress.modal_footer_note' | t | json }}}
{%- endcapture -%}
{{ 'at-discount-progress.css' | asset_url | stylesheet_tag }}
<script
  src="{{ 'at-discount-progress.js' | asset_url }}"
  type="module"
></script>

{%- unless customer -%}
  {%- if dp_layout == 'drawer_header' -%}
    <div
      class="at-discount-progress at-discount-progress--logged-out at-discount-progress--drawer-header"
      data-testid="at-discount-progress-logged-out"
    >
      <span class="at-discount-progress__label">
        {{- 'at_discount_progress.get_member_discounts' | t -}}
      </span>
      {% if shop.customer_accounts_enabled %}
        <div class="at-discount-progress__account">
          <shopify-account menu="{{ dp_customer_account_menu }}">
            <button
              type="button"
              slot="signed-out-avatar"
              class="at-discount-progress__login-trigger button button-secondary"
            >
              {{- 'at_discount_progress.log_in' | t -}}
            </button>
          </shopify-account>
        </div>
      {% else %}
        <a
          href="{{ routes.account_login_url }}"
          class="button button-secondary at-discount-progress__login at-discount-progress__login--legacy"
        >
          {{- 'at_discount_progress.log_in' | t -}}
        </a>
      {% endif %}
    </div>
  {%- else -%}
  <div
    class="at-discount-progress at-discount-progress--logged-out spacing-style"
    data-testid="at-discount-progress-logged-out"
  >
    <p class="at-discount-progress__prompt">
      {{ 'at_discount_progress.log_in_prompt' | t }}
    </p>
    {% if shop.customer_accounts_enabled %}
      <div class="at-discount-progress__account">
        <shopify-account menu="{{ dp_customer_account_menu }}">
          <span
            slot="signed-out-avatar"
            class="at-discount-progress__account-trigger button"
          >
            <span
              class="svg-wrapper account-button__icon"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="17"
                viewBox="0 0 15 17"
                fill="none"
              >
                <path
                  stroke="currentColor"
                  stroke-linejoin="round"
                  stroke-width="var(--icon-stroke-width)"
                  d="M10.375 3.813a3.063 3.063 0 1 1-6.125 0 3.063 3.063 0 0 1 6.125 0ZM7.313 9.5c-3.667 0-6.24 2.691-6.563 6.125h13.125C13.552 12.191 10.979 9.5 7.312 9.5Z"
                />
              </svg>
            </span>
            <span class="at-discount-progress__login-label">
              {{- 'at_discount_progress.log_in' | t -}}
            </span>
          </span>
        </shopify-account>
      </div>
    {% else %}
      <a
        href="{{ routes.account_login_url }}"
        class="button at-discount-progress__login at-discount-progress__login--legacy"
      >
        <span
          class="svg-wrapper account-button__icon"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="17"
            viewBox="0 0 15 17"
            fill="none"
          >
            <path
              stroke="currentColor"
              stroke-linejoin="round"
              stroke-width="var(--icon-stroke-width)"
              d="M10.375 3.813a3.063 3.063 0 1 1-6.125 0 3.063 3.063 0 0 1 6.125 0ZM7.313 9.5c-3.667 0-6.24 2.691-6.563 6.125h13.125C13.552 12.191 10.979 9.5 7.312 9.5Z"
            />
          </svg>
        </span>
        <span class="at-discount-progress__login-label">
          {{- 'at_discount_progress.log_in' | t -}}
        </span>
      </a>
    {% endif %}
  </div>
  {%- endif -%}
{%- else -%}
  {%- if settings.at_discount_progress_enabled -%}
    <template id="at-dp-truck-{{ dp_uid }}">
      <span class="svg-wrapper at-dp__icon at-dp__icon--truck" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          {%- render 'icon', icon: 'truck' -%}
        </svg>
      </span>
    </template>
    <template id="at-dp-check-{{ dp_uid }}">
      <span class="svg-wrapper add-to-cart__added-icon at-dp__icon at-dp__icon--check" aria-hidden="true">
        {{- 'icon-checkmark-burst.svg' | inline_asset_content -}}
      </span>
    </template>
    <template id="at-dp-lock-{{ dp_uid }}">
      <span class="svg-wrapper at-dp__icon at-dp__icon--lock" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          {%- render 'icon', icon: 'lock' -%}
        </svg>
      </span>
    </template>
    <template id="at-dp-close-{{ dp_uid }}">
      <span class="svg-wrapper" aria-hidden="true">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </template>
  {%- endif -%}
  {%- comment -%}
    AT: omit cart-drawer-inner only morphs keyed nodes — this bar is morphed as part of the header section.
    Server HTML is an empty custom element; JS fills children. Morph's updateChildren would strip those
    children to match SSR unless we skip subtree updates (see assets/morph.js).
  {%- endcomment -%}
  <at-discount-progress-bar
    class="at-discount-progress at-dp-empty-track--{{ dp_empty_track }}"
    data-skip-subtree-update
    data-context="{{ dp_context | escape }}"
    data-section-uid="{{ dp_uid | escape }}"
    data-subtotal="{{ dp_subtotal }}"
    data-milestones="{{ milestones_json | escape }}"
    data-money-format="{{ shop.money_format | escape }}"
    data-currency="{{ shop.currency | escape }}"
    data-product-id="{{ dp_product_id }}"
    data-variant-price="{{ dp_product_price }}"
    data-non-sale-url="{{ dp_non_sale_url | default: '' | escape }}"
    data-i18n="{{ dp_i18n | strip_newlines | escape }}"
    data-testid="at-discount-progress-bar"
  ></at-discount-progress-bar>
{%- endunless -%}
