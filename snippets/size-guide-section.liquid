{%- doc -%}
  Renders one size guide JSON section (heading, description, table, notes).

  @param {object} guide_section - Section object from size guide JSON (required)
  @param {string} section_uid - Unique suffix for heading id (required)
{%- enddoc -%}
{%- liquid
  assign section_uid = section_uid | default: '0'
  assign gs_heading = guide_section.heading | default: ''
  assign gs_desc = guide_section.description | default: ''
  assign gs_columns = guide_section.columns
  assign gs_rows = guide_section.rows
  assign gs_notes = guide_section.notes

  assign heading_element_id = 'size-guide-sec-' | append: section_uid

  assign col_count = 0
  if gs_columns != blank
    for col_item in gs_columns
      assign col_count = col_count | plus: 1
    endfor
  endif
-%}

{%- if gs_heading != blank -%}
  {%- capture sec_heading_clean -%}{% render 'size-guide-sanitize-text', text: gs_heading %}{%- endcapture -%}
  {%- assign sec_heading_clean = sec_heading_clean | strip -%}
{%- endif -%}

<section class="size-guide__section">
  {%- if sec_heading_clean != blank -%}
    <h3
      class="size-guide__section-heading"
      id="{{ heading_element_id }}"
    >
      {{- sec_heading_clean | escape -}}
    </h3>
  {%- endif -%}

  {%- if gs_desc != blank -%}
    {%- capture gs_desc_clean -%}{% render 'size-guide-sanitize-text', text: gs_desc %}{%- endcapture -%}
    {%- assign gs_desc_clean = gs_desc_clean | strip -%}
    {%- capture gs_desc_suppress -%}{% render 'size-guide-suppress-boilerplate-text', text: gs_desc_clean %}{%- endcapture -%}
    {%- if gs_desc_clean != blank and gs_desc_suppress != '1' -%}
      <p class="size-guide__section-desc paragraph">{{ gs_desc_clean | escape }}</p>
    {%- endif -%}
  {%- endif -%}

  {%- if gs_rows != blank and col_count > 0 -%}
    <div class="size-guide__scroll rte-table-wrapper">
      <table
        class="size-guide__table size-guide__table--responsive"
        {% if sec_heading_clean != blank %}
          aria-labelledby="{{ heading_element_id }}"
        {% else %}
          aria-label="{{ 'products.size_guide.table_fallback' | t }}"
        {% endif %}
      >
        <thead>
          <tr>
            <th scope="col">
              {{- 'products.size_guide.measurement_label' | t -}}
            </th>
            {%- for col in gs_columns -%}
              {%- capture col_clean -%}{% render 'size-guide-sanitize-text', text: col %}{%- endcapture -%}
              <th scope="col">{{ col_clean | strip | escape }}</th>
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for row in gs_rows -%}
            {%- liquid
              assign val_arr = row['values']
              assign row_label = row.display_label | default: row.source_label | default: ''
            -%}
            {%- capture row_label_clean -%}{% render 'size-guide-sanitize-text', text: row_label %}{%- endcapture -%}
            <tr>
              <th
                class="size-guide__label-cell"
                scope="row"
              >
                {{- row_label_clean | strip | escape -}}
              </th>
              {%- for col in gs_columns -%}
                {%- liquid
                  assign ci = forloop.index0
                  assign cell = val_arr[ci]
                -%}
                {%- capture col_label_clean -%}{% render 'size-guide-sanitize-text', text: col %}{%- endcapture -%}
                {%- capture cell_clean -%}{% render 'size-guide-sanitize-text', text: cell %}{%- endcapture -%}
                <td
                  class="size-guide__value-cell"
                  data-size-label="{{ col_label_clean | strip | escape }}"
                >
                  {{- cell_clean | strip | escape -}}
                </td>
              {%- endfor -%}
            </tr>
            {%- assign row_note = row.note | default: '' -%}
            {%- if row_note != blank -%}
              {%- capture row_note_clean -%}{% render 'size-guide-sanitize-text', text: row_note %}{%- endcapture -%}
              {%- assign row_note_clean = row_note_clean | strip -%}
              {%- capture row_note_suppress -%}{% render 'size-guide-suppress-boilerplate-text', text: row_note_clean %}{%- endcapture -%}
              {%- if row_note_clean != blank and row_note_suppress != '1' -%}
                <tr class="size-guide__row-note">
                  <td class="size-guide__row-note-spacer"></td>
                  <td colspan="{{ col_count }}">{{ row_note_clean | escape }}</td>
                </tr>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  {%- elsif gs_rows != blank and col_count == 0 -%}
    <div class="size-guide__scroll rte-table-wrapper">
      <table
        class="size-guide__table size-guide__table--responsive"
        {% if sec_heading_clean != blank %}
          aria-labelledby="{{ heading_element_id }}"
        {% else %}
          aria-label="{{ 'products.size_guide.table_fallback' | t }}"
        {% endif %}
      >
        <tbody>
          {%- for row in gs_rows -%}
            {%- liquid
              assign val_arr = row['values']
              assign row_label = row.display_label | default: row.source_label | default: ''
              assign joined_vals = val_arr | join: ', '
            -%}
            {%- capture row_label_clean -%}{% render 'size-guide-sanitize-text', text: row_label %}{%- endcapture -%}
            {%- capture joined_clean -%}{% render 'size-guide-sanitize-text', text: joined_vals %}{%- endcapture -%}
            <tr>
              <th
                class="size-guide__label-cell"
                scope="row"
              >
                {{- row_label_clean | strip | escape -}}
              </th>
              <td class="size-guide__value-cell size-guide__value-cell--plain">{{ joined_clean | strip | escape }}</td>
            </tr>
            {%- assign row_note = row.note | default: '' -%}
            {%- if row_note != blank -%}
              {%- capture row_note_clean -%}{% render 'size-guide-sanitize-text', text: row_note %}{%- endcapture -%}
              {%- assign row_note_clean = row_note_clean | strip -%}
              {%- capture row_note_suppress -%}{% render 'size-guide-suppress-boilerplate-text', text: row_note_clean %}{%- endcapture -%}
              {%- if row_note_clean != blank and row_note_suppress != '1' -%}
                <tr class="size-guide__row-note">
                  <td class="size-guide__row-note-spacer"></td>
                  <td>{{ row_note_clean | escape }}</td>
                </tr>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  {%- endif -%}

  {%- if gs_notes != blank -%}
    {%- capture gs_section_notes_inner -%}
      {%- for note in gs_notes -%}
        {%- if note != blank -%}
          {%- capture note_clean -%}{% render 'size-guide-sanitize-text', text: note %}{%- endcapture -%}
          {%- assign note_clean = note_clean | strip -%}
          {%- capture note_suppress -%}{% render 'size-guide-suppress-boilerplate-text', text: note_clean %}{%- endcapture -%}
          {%- if note_clean != blank and note_suppress != '1' -%}
            <li>{{ note_clean | escape }}</li>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}
    {%- assign gs_section_notes_inner = gs_section_notes_inner | strip -%}
    {%- if gs_section_notes_inner != blank -%}
      <div class="size-guide__section-notes rte">
        <ul>
          {{ gs_section_notes_inner }}
        </ul>
      </div>
    {%- endif -%}
  {%- endif -%}
</section>
