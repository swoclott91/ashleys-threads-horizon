{%- comment -%}
  AT: Nested bulk grid dialog for the quick-add modal context (modal-in-modal).
  Rendered inside quick-add-modal.liquid so it exists in the DOM on every page
  that has the quick-add modal, ready for any product's bulk trigger.

  Assets are loaded here (not just in at-buy-buttons.liquid) because the
  quick-add modal appears on collection and home pages where at-buy-buttons.liquid
  never renders. Without loading these here, at-bulk-grid.js would not be
  initialized on those pages and the capture-phase click interceptor would
  never be set up.

  JS: at-bulk-grid.js → initQuickAddBulkGrid() finds this via:
    - #at-bulk-grid-quick-add-dialog  (the dialog element)
    - #at-bulk-grid-quick-add-close   (the close button)
    - [data-at-bulk-grid]             (the grid container)

  The <dialog> is display:none until showModal() is called – nothing here
  is visible while the dialog is closed.
{%- endcomment -%}
{{ 'at-bulk-grid.css' | asset_url | stylesheet_tag }}
<script
  src="{{ 'at-bulk-grid.js' | asset_url }}?v=5"
  type="module"
></script>
<dialog
  id="at-bulk-grid-quick-add-dialog"
  class="at-bulk-grid-modal__dialog color-custom-popover"
  aria-labelledby="at-bulk-grid-quick-add-heading"
>
  <h2
    id="at-bulk-grid-quick-add-heading"
    class="visually-hidden"
  >
    Bulk Add to Cart
  </h2>

  <div class="at-bulk-grid-modal__inner">
    {% if settings.at_discount_progress_enabled %}
      <div class="at-dp-condensed-strip--tight at-discount-progress-scheme-wrap">
        {% render 'at-discount-progress',
          context: 'bulk-modal',
          layout: 'drawer_header',
          section_id: 'at-bulk-quick-add',
          non_sale_collection_url: settings.at_non_sale_collection_url
        %}
      </div>
    {% endif %}
    <div
      class="at-bulk-grid"
      data-at-bulk-grid
      data-at-bulk-loading-label="{{ 'accessibility.loading_variants' | t }}"
      data-at-bulk-add-to-cart-animation="{{ settings.add_to_cart_animation }}"
      data-at-bulk-auto-open-cart="{{ settings.auto_open_cart_drawer }}"
    ></div>
  </div>

  <button
    id="at-bulk-grid-quick-add-close"
    class="button button-unstyled close-button at-bulk-grid-modal__close"
    aria-label="{{ 'accessibility.close_dialog' | t }}"
    type="button"
  >
    {{- 'icon-close.svg' | inline_asset_content -}}
  </button>
</dialog>
